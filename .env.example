# Copia questo file in ".env" e compila i valori.

# === Astria ===
# Chiave API — https://www.astria.ai/users/edit#api
ASTRIA_API_KEY=
# Modello base (default Flux1.dev, il migliore per headshot)
ASTRIA_BASE_TUNE_ID=1504944
# Modello base per le anteprime FaceID (SD economico, default Realistic Vision v5.1)
ASTRIA_FACEID_BASE_ID=690204
# Preset addestramento Flux (default flux-lora-portrait: economico + qualità per headshot)
ASTRIA_PRESET=flux-lora-portrait
# MODALITÀ PACK (opzionale): usa un pack curato dal team Astria al posto dei
# nostri stili. Es. 260 = "Corporate Headshots" (astria.ai/p/corporate-headshots),
# ~52-56 foto per ordine, costo da verificare (GET https://api.astria.ai/p).
# Vuoto (default) = usa i nostri stili di styles.js: stesso stack tecnico
# (Flux1.dev + flux-lora-portrait + super-res + face inpainting), margini migliori.
ASTRIA_PACK_ID=
# Metti 1 per testare GRATIS con immagini mock (branch=fast). 0 per produzione.
ASTRIA_TEST_MODE=1

# === REALISMO (riduce l'effetto "plastica" di Flux) ===
# cfg_scale: più basso = pelle più naturale (Flux default ~3.5). Consigliato 2.8-3.2.
ASTRIA_CFG=3
# Grana fotografica (1 = on). Rende le foto meno "digitali".
ASTRIA_FILM_GRAIN=1
# Color grading su pellicola: Film Portra | Film Velvia | Ektar (vuoto = nessuno)
ASTRIA_COLOR_GRADING=Film Portra
# Negative prompt: usato SOLO per l'anteprima FaceID (base SD1.5).
# Flux IGNORA i negative prompt — il realismo è espresso in positivo in styles.js.
ASTRIA_NEG=plastic skin, waxy skin, airbrushed, oversmoothed, blurry skin, cgi, 3d render, doll-like, artificial
# Step di diffusione (vuoto = default Astria; 28-36 consigliati)
ASTRIA_STEPS=
# face_swap: usa le foto di training per aumentare la somiglianza (1 = on).
# Provalo se i clienti segnalano "non mi somiglia"; può irrigidire l'espressione.
ASTRIA_FACE_SWAP=0

# Lato corto minimo (px) delle foto caricate. Blocca screenshot/foto da chat.
MIN_PHOTO_SIDE=512

# === Server ===
# URL pubblico raggiungibile da Astria/Stripe (in locale: ngrok http 3000)
PUBLIC_BASE_URL=
PORT=3000

# === Prezzi (centesimi) ===
PRICE_STANDARD_CENTS=1990
PRICE_PRO_CENTS=3490
PRICE_STUDIO_CENTS=4990

# === Stripe ===
# https://dashboard.stripe.com/apikeys (usa le chiavi "test" all'inizio)
STRIPE_SECRET_KEY=
# Segreto del webhook: lo ottieni creando il webhook nel dashboard Stripe,
# endpoint: <PUBLIC_BASE_URL>/api/webhooks/stripe, evento checkout.session.completed
STRIPE_WEBHOOK_SECRET=

# === Sicurezza e robustezza ===
# Segreto aggiunto agli URL di callback Astria (genera una stringa lunga casuale).
# Senza, chiunque conosca un orderId può manipolare gli ordini.
CALLBACK_SECRET=
# Email a cui ricevere ALLARMI (ordini pagati bloccati). Mettici la tua.
ADMIN_EMAIL=
# Ogni quanti minuti il watchdog controlla/recupera ordini bloccati
WATCHDOG_MINUTES=10
# Rigenerazioni gratuite massime per ordine
REGEN_LIMIT=2

# === Email (Brevo) ===
# Chiave API da https://app.brevo.com → SMTP & API → API Keys
BREVO_API_KEY=
# Email mittente VERIFICATA su Brevo (es. la tua email)
EMAIL_FROM=
EMAIL_FROM_NAME=photodin

# === Conservazione dati (GDPR) ===
# Ore dopo le quali foto e immagini vengono cancellate automaticamente
RETENTION_HOURS=48
